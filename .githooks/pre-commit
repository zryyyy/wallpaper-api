#!/bin/sh

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|mjs|cjs|ts|mts|cts|jsx|tsx|json|jsonc)$')

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

echo "🔍 Biome: Checking and formatting staged files..."

echo "$STAGED_FILES" | xargs ./node_modules/.bin/biome check --write --no-errors-on-unmatched

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo "❌ Biome check failed. Please fix the errors above."
    exit $EXIT_CODE
fi

echo "$STAGED_FILES" | xargs git add

echo "✅ Biome check passed!"

echo "🔍 TypeScript: Checking types..."
npm run typecheck

EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
    echo "❌ TypeScript type check failed. Please fix the errors."
    exit $EXIT_CODE
fi

exit 0