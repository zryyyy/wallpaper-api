{
  "name": "wallpaper-api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:unsafe": "biome check --write --unsafe .",
    "fmt": "biome format .",
    "fmt:fix": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "ci": "biome ci . && npm run typecheck",
    "postinstall": "npm run cf-typegen && git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@hono/valibot-validator": "^0.6.1",
    "hono": "^4.12.2",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.0",
    "@types/service-worker-mock": "^2.0.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.68.1"
  }
}
